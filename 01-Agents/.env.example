# Copy this file to `.env` and fill in the values you need.
# Each script only requires the keys for the providers/tools it actually uses;
# see the per-pattern sections in README.md to know which keys go with which file.

# -----------------------------------------------------------------------------
# LLM provider keys
# -----------------------------------------------------------------------------

# OpenAI — used by LangChain `ChatOpenAI`, the OpenAI Agents SDK, and the
# Deep Research example (`04-planning/planning_openai_deep_research.py`).
OPENAI_API_KEY=

# Google Generative AI / Gemini — used by `langchain-google-genai`, Google ADK
# (`google.adk`), and the multi-agent / routing / parallelization Gemini examples.
GOOGLE_API_KEY=

# Anthropic / Claude — used wherever a script lets you swap in Claude as the LLM.
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Search / tool API keys
# -----------------------------------------------------------------------------

# SerpAPI — used by LangChain's `google-serper` / SerpAPI tool wrappers
# (`02-react/react_langchain.py`, some `01-tool-use/` examples).
SERPAPI_API_KEY=

# Serper.dev — alternative Google-search-as-API; same role as SerpAPI in
# scripts that import `google-serper` from langchain-community.
SERPER_API_KEY=

# -----------------------------------------------------------------------------
# Google Cloud / Vertex AI
# -----------------------------------------------------------------------------

# Set to TRUE to route Gemini calls through Vertex AI instead of the public
# Google Generative AI endpoint. When TRUE, GOOGLE_API_KEY is not used; ADC
# (Application Default Credentials) is used instead.
GOOGLE_GENAI_USE_VERTEXAI=

# Vertex AI Search datastore id — used by `01-tool-use/tool_use_vertex_ai_search.py`.
DATASTORE_ID=

# OAuth client credentials — used by ADK examples that wrap a Google API
# (e.g. CalendarToolset). Optional unless you run those specific scripts.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
